# Copy this file to `.env` (which is gitignored) and fill in real values.
# docker-compose loads .env automatically; for local `uvicorn` you can
# `export $(grep -v '^#' .env | xargs)` or use a tool like direnv.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank or
# unset to disable analytics — the gtag tag is only injected when this
# variable is non-empty.
GA_MEASUREMENT_ID=
